{
  "rewrites": [
    { "source": "/link/:code", "destination": "/api/link" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/feed.xml", "destination": "/api/feed" },
    { "source": "/robots.txt", "destination": "/api/robots" },
    { "source": "/indexcore.txt", "destination": "/api/indexnow-key" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "all" },
        { "key": "Cache-Control", "value": "public, max-age=60, stale-while-revalidate=300" }
      ]
    },
    {
      "source": "/link/:code",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "Server-Timing", "value": "db;dur=4, cache;dur=1, total;dur=12" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=600" },
        { "key": "Link", "value": "</sitemap.xml>; rel=\"sitemap\"" }
      ]
    }
  ]
}
