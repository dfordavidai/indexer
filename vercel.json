{
  "functions": {
    "api/sitemap.js": { "runtime": "nodejs18.x" },
    "api/link.js":    { "runtime": "nodejs18.x" }
  },
  "rewrites": [
    { "source": "/link/:code", "destination": "/api/link?code=:code" }
  ],
  "routes": [
    { "src": "/sitemap.xml",              "dest": "/api/sitemap"                        },
    { "src": "/sitemap-pages.xml",        "dest": "/api/sitemap?type=pages"             },
    { "src": "/sitemap-news.xml",         "dest": "/api/sitemap?type=news"              },
    { "src": "/sitemap-links-([0-9]+)\\.xml", "dest": "/api/sitemap?type=links&page=$1" },
    { "src": "/sitemap-html.xml",         "dest": "/api/sitemap?type=html"              }
  ]
}
